QBITTORRENT_BASE_URL=

# qBittorrent >= 5.2.0
QBITTORRENT_API_KEY=

# legacy auth
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
# needed for qBittorrent >= 5.2.0
QBITTORRENT_COOKIE_NAME=
# QBITTORRENT_PASSWORD_FILE=

# exporter settings
# QBITTORRENT_BASIC_AUTH_USERNAME=
# QBITTORRENT_BASIC_AUTH_PASSWORD=
EXPORTER_PORT=
# EXPORTER_HOST=
LOG_LEVEL=
QBITTORRENT_TIMEOUT=

## features
ENABLE_TRACKER=true
ENABLE_INCREASED_CARDINALITY=false
ENABLE_HIGH_CARDINALITY=false

## experimental features
ENABLE_LABEL_WITH_HASH=false
ENABLE_LABEL_WITH_TAG=false
ENABLE_LABEL_WITH_TRACKER=true

## tls configuration
CERTIFICATE_AUTHORITY_PATH=
INSECURE_SKIP_VERIFY=false
MIN_TLS_VERSION=TLS_1_3
